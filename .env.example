# Azure OpenAI
OPENAI_HOST=azure
AZURE_OPENAI_SERVICE=your-openai-resource-name
AZURE_OPENAI_ENDPOINT=https://eastus.api.cognitive.microsoft.com/
AZURE_OPENAI_CHATGPT_DEPLOYMENT=your-gpt4o-deployment-name
AZURE_OPENAI_CHATGPT_MODEL=gpt-4o
AZURE_OPENAI_EMB_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_EMB_MODEL_NAME=text-embedding-3-small
AZURE_OPENAI_API_KEY_OVERRIDE=your-azure-openai-api-key

# Azure AI Search
AZURE_SEARCH_SERVICE=your-search-service-name
AZURE_SEARCH_INDEX=default
AZURE_SEARCH_ADMIN_KEY=your-search-admin-key

# Azure Blob Storage
AZURE_STORAGE_ACCOUNT=your-storage-account-name
AZURE_STORAGE_CONTAINER=content
AZURE_STORAGE_KEY=your-storage-account-key

# Feature flags
USE_VECTORS=true
RAG_SEARCH_TEXT_EMBEDDINGS=true
RAG_SEARCH_IMAGE_EMBEDDINGS=false
